# Environment Variables Example

# Copy this file to .env.local and update with actual values
# NOTE: Do not commit .env.local to version control

# API Configuration
REACT_APP_NAME=Portfolio
REACT_APP_VERSION=2.0.0

# Contact Email
REACT_APP_CONTACT_EMAIL=TapadiyaMS@Gmail.com

# Social Links
REACT_APP_GITHUB=https://GitHub.com/TapadiyaMS
REACT_APP_LINKEDIN=https://www.LinkedIN.com/in/TapadiyaMS/

# Feature Flags
REACT_APP_ENABLE_ANIMATIONS=true
REACT_APP_ENABLE_PARTICLES=true

